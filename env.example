# ──────────────────────────────────────────────────────────────────────────────
# Docling Image Loader – environment configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── This service ──────────────────────────────────────────────────────────────
# The API key that Open-WebUI sends in the Authorization: Bearer <key> header.
# Set the same value in Open-WebUI under:
#   Settings → Documents → External Document Loader API Key
API_KEY=change-me-super-secret

HOST=0.0.0.0
PORT=8081

# ── Docling ───────────────────────────────────────────────────────────────────
DOCLING_URL=http://docling:5001

# Optional – only if your Docling instance requires auth
DOCLING_API_KEY=

# Optional – extra Docling params as a JSON object string
# e.g. DOCLING_EXTRA_PARAMS={"ocr_enabled": true}
DOCLING_EXTRA_PARAMS=

# Docling request timeout in seconds. 0 = no timeout (same as Open-WebUI default).
# Large PDFs/presentations can take several minutes – only set this if you need a hard limit.
DOCLING_TIMEOUT=0

# ── Storage backend ───────────────────────────────────────────────────────────
# Where to persist extracted images. One of: azure | local | both
#   azure → upload to Azure Blob Storage only (default; original behaviour)
#   local → write to a directory on disk only (good for air-gapped / on-prem)
#   both  → write to both; the markdown URL points at the Azure copy
STORAGE_BACKEND=azure

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Required when STORAGE_BACKEND is "azure" or "both".
# Option A: connection string (recommended – easiest to get from Azure portal)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOURACCOUNTNAME;AccountKey=YOURACCOUNTKEY;EndpointSuffix=core.windows.net

# Option B: separate account name + key (leave AZURE_STORAGE_CONNECTION_STRING empty)
# AZURE_STORAGE_ACCOUNT_NAME=YOURACCOUNTNAME
# AZURE_STORAGE_ACCOUNT_KEY=YOURACCOUNTKEY

# The blob container name. Must already exist in your storage account.
# Set it to allow "Blob (anonymous read access for blobs only)"
AZURE_STORAGE_CONTAINER=docling-images

# ── Local file storage ────────────────────────────────────────────────────────
# Used when STORAGE_BACKEND is "local" or "both"; ignored otherwise.

# Directory where image files are written. Created on startup if missing.
# In Docker, mount a host volume here (see docker-compose.yml).
# When running as a plain service (uvicorn), use any writable absolute path,
# e.g. ./images on Linux/macOS, C:\docling-images on Windows.
LOCAL_STORAGE_PATH=/data/images

# Externally-reachable URL prefix that Open-WebUI will use to fetch the images.
# The image filename (<sha>.<ext>) is appended to this prefix in the markdown.
# Required when STORAGE_BACKEND includes "local".
# Examples:
#   http://docling-image-loader:8081/images   (inside the same docker compose network)
#   http://localhost:8081/images              (running as a local dev service)
#   https://docs.example.com/images           (behind a reverse proxy / public)
LOCAL_STORAGE_URL_PREFIX=http://docling-image-loader:8081/images
